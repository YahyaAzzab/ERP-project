# =============================================
# VARIABLES D'ENVIRONNEMENT — ERP PME Backend
# Copier ce fichier en .env et remplir les valeurs
# NE JAMAIS committer le fichier .env dans Git !
# =============================================

# Port d'écoute du serveur Express
PORT=

# URI de connexion MongoDB
# En local : mongodb://localhost:27017/erp-pme
# En production : mongodb+srv://<user>:<password>@cluster.mongodb.net/erp-pme
MONGODB_URI=

# Clé secrète pour signer les JSON Web Tokens
# Utiliser une chaîne longue et aléatoire en production (min. 32 caractères)
JWT_SECRET=your_super_secret_key_here

# Durée de validité des tokens JWT
# Exemples : 8h (8 heures), 7d (7 jours), 30m (30 minutes)
JWT_EXPIRES_IN=8h

# Environnement d'exécution
# Valeurs possibles : development | production | test
NODE_ENV=development
